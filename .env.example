# PostgreSQL
POSTGRES_PASSWORD=devpassword

# OpenClaw
OPENCLAW_AUTH_TOKEN=your-openclaw-auth-token-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# LangSmith Observability (optional)
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=yuno-agent-factory
LANGSMITH_TRACING=true

# Admin users — format: "user1:pass1,user2:pass2"
# Supports bcrypt hashes: "user1:$2b$12$...,user2:$2b$12$..."
ADMIN_USERS=admin:changeme
# Set AUTH_DISABLED=true to explicitly run without authentication
# AUTH_DISABLED=false

# Frontend
HOST_IP=localhost

# Gemini (for OpenClaw web search)
GEMINI_API_KEY=your-gemini-api-key-here

# Security settings (defaults are production-safe)
# DOCS_ENABLED=false
# DEBUG_ENDPOINTS_ENABLED=false
# ALLOWED_ORIGINS=http://localhost:3001
